{
  "name": "integration-huron-person-lambda",
  "description": "A serverless dashboard for managing integration operations between BU CDM and Huron systems",
  "version": "0.1.0",
  "bin": {
    "integration-huron-person-lambda": "bin/App.js"
  },
  "scripts": {
    "clearcache": "sh bin/clear-cache.sh",
    "build": "npm run build:templates && tsc",
    "build:templates": "ts-node scripts/BuildTemplates.ts",
    "watch": "tsc -w",
    "test": "jest",
    "cdk": "cdk",
    "publish-dev": "sh ./bin/publish-to-bucket.sh",
    "dev": "npm run build && ts-node src/LocalServer.ts",
    "dev:watch": "npm run build:templates && nodemon --exec ts-node --transpile-only src/LocalServer.ts",
    "get-stack-name": "ts-node -e \"require('./src/Utils.ts').echoStackName()\"",
    "synth": "npm run get-stack-name | xargs cdk synth 2>&1 | tee cdk.out/synth.output.yaml",
    "deploy": "npm run build:templates && cdk deploy --all --no-rollback --require-approval never",
    "redeploy": "cdk destroy --all -f && npm run deploy --all",
    "teardown": "cdk destroy -f"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.145",
    "@types/express": "^4.17.21",
    "@types/html-minifier-terser": "^7.0.2",
    "@types/jest": "^29.5.14",
    "@types/mustache": "^4.2.5",
    "@types/node": "^24.10.1",
    "aws-cdk": "2.1033.0",
    "esbuild": "^0.27.2",
    "html-minifier-terser": "^7.2.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.7",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.3"
  },
  "dependencies": {
    "aws-cdk-lib": "2.235.1",
    "constructs": "^10.0.0",
    "express": "^4.19.2",
    "integration-huron-person": "file:../integration-huron-person/integration-huron-person-1.0.0.tgz",
    "mustache": "^4.2.0",
    "shibboleth-sp-at-edge": "file:../../../wp_to_cloud/bu-lambda-shibboleth/shibboleth-sp-at-edge-1.0.0.tgz"
  },
  "overrides": {
    "tar": "^7.5.6",
    "js-yaml": "^3.14.2"
  }
}
