<!-- System Status Tab -->
<div class="tab-pane fade {{#systemActive}}show active{{/systemActive}}" id="system" role="tabpanel" aria-labelledby="system-tab">
    <div class="row mt-4">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header">
                    <h5><i class="fas fa-server me-2"></i>Service Health</h5>
                </div>
                <div class="card-body">
                    <div id="serviceStatus">
                        <div class="text-center">
                            <div class="spinner-border text-primary" role="status">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                            <p class="mt-2">Checking service status...</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card">
                <div class="card-header">
                    <h5><i class="fas fa-chart-line me-2"></i>Metrics</h5>
                </div>
                <div class="card-body">
                    <div id="systemMetrics">
                        <div class="text-center">
                            <div class="spinner-border text-primary" role="status">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>