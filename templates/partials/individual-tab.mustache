<!-- Individual Sync Tab -->
<div class="tab-pane fade {{#individualActive}}show active{{/individualActive}}" 
     id="individual" 
     role="tabpanel" 
     aria-labelledby="individual-tab">
    <div class="row mt-4 justify-content-center">
        <div class="col-auto" style="min-width: 50%; max-width: 100%;">
            <div class="card">
                <div class="card-header">
                    <h5><i class="fas fa-user me-2"></i>Person Lookup & Sync</h5>
                </div>
                <div class="card-body">
                    <form id="personLookupForm">
                        <div class="mb-3">
                            <div class="d-flex align-items-center justify-content-between mb-2">
                                <label for="personId" class="form-label mb-0">Person ID</label>
                                <div class="form-check-inline">
                                    <input class="form-check-input" type="radio" name="systemType" id="buidRadio" value="source" checked>
                                    <label class="form-check-label me-3" for="buidRadio">BUID</label>
                                    <input class="form-check-input" type="radio" name="systemType" id="hrnRadio" value="target">
                                    <label class="form-check-label" for="hrnRadio">HRN</label>
                                </div>
                            </div>
                            <div class="input-group">
                                <input type="text" 
                                       class="form-control" 
                                       id="personId" 
                                       placeholder="Enter BUID here..."
                                       required>
                                <button class="btn btn-outline-primary" type="submit">
                                    <span class="loading-spinner spinner-border spinner-border-sm me-2"></span>
                                    Lookup
                                </button>
                            </div>
                        </div>
                    </form>
                    <div id="personResults"></div>
                </div>
            </div>
        </div>
    </div>
</div>